# ─── Supabase (project: nmakvepkslzrejsnpmsy) ───────────────────────────────
# Dashboard: https://supabase.com/dashboard/project/nmakvepkslzrejsnpmsy/settings/api

# Direct Postgres (SQL clients, migrations) — replace [YOUR-PASSWORD]
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.nmakvepkslzrejsnpmsy.supabase.co:5432/postgres

NEXT_PUBLIC_SUPABASE_URL=https://nmakvepkslzrejsnpmsy.supabase.co

# Publishable key is enough for the lead form (with RLS insert policy in supabase/schema.sql)
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Legacy name — still supported if you prefer
# NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Recommended for /api/leads (insert + update without RLS errors)
SUPABASE_SERVICE_ROLE_KEY=

# ─── Resend (https://resend.com/api-keys) ───────────────────────────────────
# Confirmation emails go TO the address submitted on the form.
# EMAIL_TO is optional — internal copy for your team inbox.
RESEND_API_KEY=
EMAIL_FROM=hello@brandcure.in
EMAIL_TO=team@example.com,other@example.com

# ─── Sanity CMS (optional) ────────────────────────────────────────────────────
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=
SANITY_REVALIDATION_SECRET=

# ─── AI Chat (optional) ───────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# ─── ElevenLabs TTS (required for voice agent speech) ─────────────────────────
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
# Optional voice — pick from https://elevenlabs.io/app/voice-library
# ELEVENLABS_VOICE_ID=EXAVITQu4vr4xnSDxMaL
# Low-latency model for call mode (default: eleven_flash_v2_5)
# Alternatives: eleven_multilingual_v2, eleven_v3, eleven_turbo_v2_5
# ELEVENLABS_MODEL_ID=eleven_flash_v2_5

# ─── Site (SEO: canonical URLs, sitemap, Open Graph) ─────────────────────────
# Production must use the www host (apex redirects to www on Vercel).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Vercel production example: NEXT_PUBLIC_SITE_URL=https://www.brandcure.in

# Optional — Google Search Console HTML tag verification

# ─── Analytics (optional — omit in local dev to avoid noise) ───────────────────
# GA4: Admin → Data Streams → Web → Measurement ID (G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-R4HKCZKM4S
# Clarity: https://clarity.microsoft.com → Project → Settings → Setup
NEXT_PUBLIC_CLARITY_PROJECT_ID=wz6v914r09
